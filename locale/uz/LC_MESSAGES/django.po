#: prime/templates/prime/help.html
msgid "Go to your Profile page after logging in."
msgstr "Kirganingizdan so'ng Profil sahifangizga o'ting."

#: prime/templates/prime/help.html
msgid "Scroll to the Masters section and use the selector to add the masters you want to follow."
msgstr "Ustodlar bo'limiga o'ting va kuzatmoqchi bo'lgan ustodlarni qo'shish uchun tanlagichdan foydalaning."

#: prime/templates/prime/help.html
msgid "Save your profile. The master's practices and homework will now be accessible to you."
msgstr "Profilingizni saqlang. Ustodning mashqlari va uy vazifalari endi sizga ochiq bo'ladi."

#: prime/templates/prime/help.html
msgid "You can follow multiple masters at the same time."
msgstr "Bir vaqtning o'zida bir nechta ustodga obuna bo'lish mumkin."

#: prime/templates/prime/help.html
msgid "Remove a master from your selector at any time to unfollow."
msgstr "Obunani bekor qilish uchun istalgan vaqt tanlagichdan ustodni o'chiring."

#: prime/templates/prime/help.html
msgid "How it looks"
msgstr "Qanday ko'rinadi"

#: prime/templates/prime/help.html
msgid "Browse Masters page"
msgstr "Ustodlar sahifasini ko'rish"

#: prime/templates/prime/help.html
msgid "View master profile & practices"
msgstr "Ustod profili va mashqlarini ko'rish"

